# ==========================================
# 🐍 PYTHON & BACKEND (FastAPI, SQLAlchemy)
# ==========================================
# Кэш питона (то, что вызвало у вас панику)
__pycache__/
*.py[cod]
*$py.class

# Виртуальные окружения (весят много, у каждого разработчика свои)
venv/
env/
.venv/
env.bak/

# Локальные базы данных (чтобы случайно не залить базу с реальными юзерами)
*.sqlite3
*.db
test.db

# ==========================================
# ⚛️ NODE.JS & FRONTEND (React, Vite)
# ==========================================
# Папка с библиотеками (самая тяжелая папка во вселенной)
node_modules/
jspm_packages/

# Сборка проекта (то, что Vite генерирует для продакшена)
dist/
build/
dist-ssr/

# Логи ошибок npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Кэш линтеров
.eslintcache

# ==========================================
# 🔐 БЕЗОПАСНОСТЬ (Секреты и ключи)
# ==========================================
# Файлы с паролями от БД, API ключами (НИКОГДА не заливать на GitHub!)
.env
.env.local
.env*.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# ==========================================
# 💻 ОПЕРАЦИОННЫЕ СИСТЕМЫ И РЕДАКТОРЫ
# ==========================================
# Системные файлы Windows и macOS
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# Настройки редакторов кода (VS Code, PyCharm и т.д.)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?